# Supabase (optional — app falls back to an in-memory mock store if unset)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin panel (/admin) password gate. If unset, /admin is left open (dev convenience).
ADMIN_PASSWORD=
# Secret used to sign the admin session cookie. Set any random string in production.
ADMIN_COOKIE_SECRET=dev-secret-change-me

# Display name shown on the dashboard header, e.g. "Héctor y Liz"
NEXT_PUBLIC_PARENT_NAMES=Héctor y Liz
